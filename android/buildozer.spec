[app]
title = Breakout
package.name = breakout
package.domain = org.estudiante
source.dir = ..
source.include_exts = py
version = 1.0.0
requirements = python3==3.10.12,pygame,sdl2,sdl2_image,sdl2_mixer,sdl2_ttf
orientation = landscape
fullscreen = 1
android.api = 31
android.minapi = 21
android.permissions = INTERNET
android.archs = arm64-v8a, armeabi-v7a
log_level = 2

[buildozer]
warn_on_root = 1
